# ============================================
# RechnungTracker Environment Variables
# ============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=rechnungtracker
POSTGRES_PASSWORD=changeme-use-strong-password
POSTGRES_DB=rechnungtracker
DATABASE_URL=postgresql://rechnungtracker:changeme-use-strong-password@db:5432/rechnungtracker

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- Seed Admin Account ---
# Generate with: openssl rand -base64 16
# This password is used for the initial Owner account (admin@rechnungtracker.local)
# Store it securely — there is no password change feature in MVP.
SEED_ADMIN_EMAIL=admin@rechnungtracker.local
SEED_ADMIN_PASSWORD=changeme-generate-with-openssl-rand-base64-16
SEED_ADMIN_NAME=Admin

# --- Parser Service ---
PARSER_URL=http://parser:8000

# --- File Storage ---
UPLOAD_DIR=/app/storage/uploads
MAX_FILE_SIZE_MB=20

# --- App Boot Phase ---
# Do NOT set this here. It is controlled via docker-compose.phase0.yml override.
# Default is 1 (production). Phase 0 is for initial scaffold validation only.
# APP_BOOT_PHASE=1
