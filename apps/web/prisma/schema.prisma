generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  WORKER
  ACCOUNTANT
  OWNER
}

enum ProcessingStatus {
  UPLOADED
  QUEUED
  PROCESSING
  PARSED
  FAILED_PARSE
}

enum ReviewStatus {
  PENDING
  NEEDS_REVIEW
  VERIFIED
  REJECTED
}

enum ReviewAction {
  APPROVED
  REJECTED
  EDITED
}

// ─── User ────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploadedInvoices Invoice[]
  reviews          InvoiceReview[]

  @@map("users")
}

// ─── Supplier ────────────────────────────────────────────

model Supplier {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  address        String?
  taxId          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices Invoice[]

  @@map("suppliers")
}

// ─── Invoice ─────────────────────────────────────────────

model Invoice {
  id               String           @id @default(cuid())
  invoiceNumber    String?
  invoiceDate      DateTime?
  dueDate          DateTime?
  subtotal         Decimal?         @db.Decimal(12, 2)
  taxAmount        Decimal?         @db.Decimal(12, 2)
  totalAmount      Decimal?         @db.Decimal(12, 2)
  currency         String           @default("EUR")
  processingStatus ProcessingStatus @default(UPLOADED)
  reviewStatus     ReviewStatus     @default(PENDING)
  originalFilename String
  storedFilename   String
  filePath         String
  fileHash         String           @unique
  fileSizeBytes    Int
  pageCount        Int?
  parserVersion    String?
  parserConfidence Float?
  parserRawOutput  Json?
  parseError       String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
  uploadedById String
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  supplierId   String?

  items   InvoiceItem[]
  reviews InvoiceReview[]

  @@index([processingStatus])
  @@index([reviewStatus])
  @@index([supplierId])
  @@index([invoiceDate])
  @@index([uploadedById])
  @@index([deletedAt])
  @@index([processingStatus, reviewStatus, supplierId, invoiceDate])
  @@map("invoices")
}

// ─── InvoiceItem ─────────────────────────────────────────

model InvoiceItem {
  id           String   @id @default(cuid())
  lineNumber   Int
  description  String
  quantity     Decimal  @db.Decimal(10, 3)
  unit         String?
  unitPrice    Decimal  @db.Decimal(12, 4)
  totalPrice   Decimal  @db.Decimal(12, 2)
  taxRate      Decimal? @db.Decimal(5, 2)
  isEdited     Boolean  @default(false)
  editedFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─── InvoiceReview ───────────────────────────────────────

model InvoiceReview {
  id        String       @id @default(cuid())
  action    ReviewAction
  comment   String?
  changes   Json?
  createdAt DateTime     @default(now())

  invoice      Invoice @relation(fields: [invoiceId], references: [id])
  invoiceId    String
  reviewedBy   User    @relation(fields: [reviewedById], references: [id])
  reviewedById String

  @@index([invoiceId])
  @@map("invoice_reviews")
}
